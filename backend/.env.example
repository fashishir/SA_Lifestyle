PORT=5000
NODE_ENV=production

# Postgres (Railway provides a DATABASE_URL, but the app reads DB_*)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=sa_lifestyle

# Or set DATABASE_URL=postgres://user:pass@host:port/db (Railway auto-provides this)

# Auth
JWT_SECRET=replace-with-a-long-random-string

# CORS
CORS_ORIGIN=https://your-frontend.up.railway.app

# File uploads
UPLOAD_DIR=./uploads
