# --- Database ---
# Precedence: if DATABASE_URL is set (Railway / Heroku / cloud), it wins.
# Otherwise, the individual DB_* vars below are used. Defaults match a
# local Postgres install with the user "postgres" and password "admin".
#
# DATABASE_URL=postgres://user:pass@host:5432/sa_lifestyle?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=sa_lifestyle

# --- App ---
PORT=5000
NODE_ENV=development

# --- Auth ---
JWT_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# --- CORS ---
# Comma-separated list of allowed origins. Empty = allow all (dev only).
CORS_ORIGIN=http://localhost:3000

# --- Uploads ---
UPLOAD_DIR=./uploads
